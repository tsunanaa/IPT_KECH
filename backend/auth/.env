# .env file for IPT_KECH Django auth project

# Django secret key (generate a strong random value)
SECRET_KEY=django-insecure-replace-this-with-a-strong-secret

# Debug mode (True for development, False for production)
DEBUG=True

# Allowed hosts (comma separated list)
ALLOWED_HOSTS=localhost,127.0.0.1

# Email settings (Brevo SMTP)
# Brevo (formerly Sendinblue) provides an SMTP relay. Replace the placeholders with your actual credentials.
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
# The SMTP username is your Brevo account email
EMAIL_HOST_USER=your_brevo_email@example.com
# The SMTP password is the API key generated in Brevo
EMAIL_HOST_PASSWORD=your_brevo_smtp_api_key

# Optional: Database path (default uses SQLite file in BASE_DIR)
# If you switch to another DB, set the appropriate connection string here.
# DATABASE_URL=sqlite:///db.sqlite3
